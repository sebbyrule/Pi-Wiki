# --- SERVER HOSTING CONFIG ---
APP_PORT=8000
# When True, raw backend error details are shown in the browser UI. Keep False in production.
DEBUG_MODE=False

# --- ACCESS SECURITY CONTROLS ---
# CHANGE THESE before exposing the app. Leaving admin/admin prints a startup warning.
WIKI_ADMIN_USER=admin
WIKI_ADMIN_PASSWORD=admin

# Arbitrary shell execution via /api/terminal and the AI's execute_bash tool.
# HIGH RISK (remote code execution). Only set to true on a trusted, isolated host.
ALLOW_TERMINAL=false

# --- SYSTEM INTEGRATION ENDPOINTS ---
# Update this IP with the address of the device hosting your LLM instance
LOCAL_AI_URL=http://10.5.0.2:1234/v1/chat/completions
LOCAL_AI_MODEL=local-model
# Max tokens the inbox synthesizer requests from the local model.
MAX_AI_TOKENS=20000

# --- EXTERNAL UI LINKS ---
HOMELAB_DASHBOARD_URL=http://localhost:8000
GITHUB_REPO_URL=https://github.com/sebbyrule/Pi-Wiki
SUPPORT_EMAIL=admin@homelab.local
